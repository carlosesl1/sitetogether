# BEGIN TOGETHER Frontend + WordPress Backend
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Keep authorization headers available for WordPress REST/API requests.
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# The public home opens the exported frontend.
RewriteRule ^$ index.html [L]

# Keep WordPress reachable when the static frontend and WP share the same
# document root. These rules must run before the frontend fallback.
RewriteRule ^wp-json/?$ index.php?rest_route=/ [QSA,L]
RewriteRule ^wp-json/(.*)$ index.php?rest_route=/$1 [QSA,L]
RewriteRule ^wp-admin/?$ wp-admin/index.php [L]
RewriteRule ^wp-admin($|/) - [L]
RewriteRule ^wp-content($|/) - [L]
RewriteRule ^wp-includes($|/) - [L]
RewriteRule ^(index\.php|xmlrpc\.php|wp-[^/]+\.php)$ - [L]

# Keep dynamic WordPress/SEO-plugin sitemaps outside the frontend.
RewriteRule ^sitemap_index\.xml$ index.php?sitemap=1 [L]
RewriteRule ^([^/]+?)-sitemap([0-9]+)?\.xml$ index.php?sitemap=$1&sitemap_n=$2 [L]

# Keep this legacy WordPress page available while the new frontend owns the
# rest of the public routes.
RewriteRule ^migracao-privacy-tools/?$ index.php [QSA,L]


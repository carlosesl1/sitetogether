# Keep internal preview routes out of the public site.
RewriteRule ^(design-system|hero-experiment)(\.html|/.*)?$ - [R=404,L]

# Serve generated/static files directly.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route extensionless URLs to the generated .html files.
# This avoids 403 on Apache when a same-name directory exists.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Return a real 404 for public routes that do not have a matching HTML file.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . - [R=404,L]

ErrorDocument 404 /404.html
</IfModule>
# END TOGETHER Frontend + WordPress Backend

# BEGIN LiteSpeed
<IfModule Litespeed>
SetEnv noabort 1
</IfModule>
# END LiteSpeed
